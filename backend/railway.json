{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": {
      "commands": [
        "composer install --optimize-autoloader --no-dev",
        "php artisan optimize"
      ]
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
